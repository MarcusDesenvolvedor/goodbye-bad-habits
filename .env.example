# Copy to .env.local and fill with real values.

# PostgreSQL (Neon, Supabase, or local)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Clerk — https://dashboard.clerk.com/last-active?path=api-keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Optional — Google Stitch API key for `npm run stitch:board-assets` (design reference only)
# STITCH_API_KEY=
